decl
 int bsort(int n);
 int swap(int a, int b);
 int arr[20];
enddecl

int swap(int a, int b){
    decl
      int temp;
    enddecl
    begin 
      temp = arr[a];
      arr[a] = arr[b];
      arr[b] = temp;
      return 0;
    end
}

int bsort(int n){
    decl
      int temp, i, j;
    enddecl
    begin
      i=0;
      while(i<(n-1)) do 
        j = 0;
        while(j < (n-i-1)) do
          if(arr[j] > arr[j+1]) then
            temp = swap(j, j+1);
          endif;
          j = j + 1;
        endwhile;
        i=i+1;
       endwhile;
      return 0;
    end
}

int main(){
    decl 
      int temp, i, n;
    enddecl
    begin
      temp = exposcall("Read", -1, n);
      i=0;
      while(i<n) do 
        temp = exposcall("Read", -1, arr[i]);
        i=i+1;
      endwhile;
      temp = bsort(n);
      i=0;
      while(i<n) do
        temp = exposcall("Write", -2, arr[i]);
        i=i+1;
      endwhile;
      return 0;
    end
}