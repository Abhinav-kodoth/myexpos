// EXIT - INT 10

[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1]*16 + 9] = 10;
[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1]*16 + 13] = SP;
SP = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1]*16 +11]*512 -1;
backup;


alias currPID R0;

currPID = [SYSTEM_STATUS_TABLE + 1];
multipush(R0);
R1 = 3;
R2 = currPID;
call MOD_1;
multipop(R0);

call MOD_5;